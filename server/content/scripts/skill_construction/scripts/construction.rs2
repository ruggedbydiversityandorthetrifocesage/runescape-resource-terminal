// Construction skill — V4 Player Housing (3×3 room grid + 12 farm patches)
//
// Architecture:
//   House instance at region (70,200):
//   x = 4480 + ((house_index-1) mod 6) * 32
//   z = 12800 + ((house_index-1) / 6) * 32
//
// Compact layout (all within +16×+20 footprint — well within 32×32 instance):
//   Exit portal: (+7,+2) — south center, visible from spawn
//   Entry/spawn: (+7,+5) — just north of portal
//   Room grid (3×3, 4 tiles apart):
//     Plot 0 (+3,+8)   Plot 1 (+7,+8)   Plot 2 (+11,+8)
//     Plot 3 (+3,+12)  Plot 4 (+7,+12)  Plot 5 (+11,+12)
//     Plot 6 (+3,+16)  Plot 7 (+7,+16)  Plot 8 (+11,+16)
//
// Farm patches (tight outer ring, 12 total):
//   South (z=+3): patches 0-3 at x=+1,+4,+10,+13
//   North (z=+19): patches 4-7 at x=+1,+4,+10,+13
//   West (x=+0):  patches 8-9 at z=+10,+14
//   East (x=+15): patches 10-11 at z=+10,+14
//
// Room types (house_room_N): 0=empty 1=Bedroom(L1) 2=Kitchen(L5) 3=Dining(L10)
//   4=Workshop(L15) 5=Trophy(L20) 6=Prayer(L45) 7=Portal(L65)
//
// Crop types (house_farm_crop_N):
//   0=none 1=harralander 2=ranarr 3=irit 4=avantoe 5=kwuarm 6=cadantine 7=torstol
//   10=oak 11=willow 12=maple 13=yew 14=magic
// Grow ticks: herbs=300 oak=600 willow=900 maple=1200 yew=1800 magic=2500

// ============================================================
// HOME PORTAL (op1=Build mode, op2=Visit)
// ============================================================

[oploc1,home_portal]
if (%house_index < 1) {
    mes("Something went wrong — no house assigned. Please relog.");
    return;
}
%building_mode = 1;
mes("You enter your house in building mode.");
anim(human_castteleport, 0);
p_delay(1);
def_coord $entry = ~house_entry_coord;
p_telejump($entry);
p_delay(1);
~house_setup_locs;

[oploc2,home_portal]
if (%house_index < 1) {
    mes("Something went wrong — no house assigned. Please relog.");
    return;
}
%building_mode = 0;
mes("You enter your house.");
anim(human_castteleport, 0);
p_delay(1);
def_coord $entry = ~house_entry_coord;
p_telejump($entry);
p_delay(1);
~house_setup_locs;

// ============================================================
// EXIT PORTAL
// ============================================================

[oploc1,house_exit_portal]
mes("You step through the exit portal...");
anim(human_castteleport, 0);
p_delay(1);
p_telejump(0_50_50_20_13);

[oploc2,house_exit_portal]
if (%building_mode = 1) {
    switch_int(~p_choice2("Building Mode: On  (click to turn off)", 1, "Leave House", 2)) {
        case 1 :
            %building_mode = 0;
            mes("Building mode is now OFF.");
        case 2 :
            mes("You step through the exit portal...");
            anim(human_castteleport, 0);
            p_delay(1);
            p_telejump(0_50_50_20_13);
    }
} else {
    switch_int(~p_choice2("Building Mode: Off (click to turn on)", 1, "Leave House", 2)) {
        case 1 :
            %building_mode = 1;
            mes("Building mode is now ON.");
        case 2 :
            mes("You step through the exit portal...");
            anim(human_castteleport, 0);
            p_delay(1);
            p_telejump(0_50_50_20_13);
    }
}

