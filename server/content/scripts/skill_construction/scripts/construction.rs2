// ============================================================
// FURNITURE INTERACTIONS
// ============================================================

[oploc1,house_bed]
mes("You flop onto the bed. Very comfortable.");

[oploc1,house_fourposter_bed]
mes("You lie back on the four-poster bed. Truly the finest sleep.");

[oploc1,house_table]
mes("You run your hand over the smooth tabletop.");

[oploc1,house_oak_table]
mes("You run your hand over the smooth oak dining table.");

[oploc1,house_teak_table]
mes("You admire the finely crafted teak dining table.");

[oploc1,house_range]
mes("You cook some food on the clay range.");
stat_advance(cooking, 2500);

[oploc1,house_steel_range]
mes("You cook on the steel range. A fine piece of equipment.");
stat_advance(cooking, 5000);

[oploc1,house_workbench]
mes("You practice your craft at the workbench.");
stat_advance(crafting, 2500);

[oploc1,house_trophy]
mes("You admire your trophy. A fine accomplishment!");

[oploc1,house_altar_limestone]
anim(human_bow, 0);
stat_advance(prayer, 10000);
mes("You kneel before the limestone altar. (10,000 Prayer XP)");

[oploc1,house_altar_marble]
anim(human_bow, 0);
stat_advance(prayer, 25000);
mes("You kneel before the marble altar. A powerful feeling washes over you. (25,000 Prayer XP)");

[oploc1,house_altar_gilded]
anim(human_bow, 0);
stat_advance(prayer, 50000);
mes("You kneel before the gilded altar. Your prayers are heard with great power. (50,000 Prayer XP)");

[oploc1,house_portal]
if (%house_portal_dest < 1) {
    mes("The portal is not yet attuned. Right-click it to set a destination.");
    return;
}
mes("You step through the portal...");
anim(human_castteleport, 0);
p_delay(1);
switch_int(%house_portal_dest) {
    case 1 : p_telejump(0_50_50_20_13);
    case 2 : p_telejump(0_49_54_19_6);
    case 3 : p_telejump(0_47_53_38_38);
    case 4 : p_telejump(0_43_53_50_50);
    case 5 : p_telejump(0_43_52_42_26);
    case default : p_telejump(0_50_50_20_13);
}

[oploc2,house_portal]
if (%building_mode = 1) {
    def_int $portchoice = ~p_choice3("Attune Portal", 1, "Remove Portal Frame", 2, "Cancel", 0);
    if ($portchoice = 0) { return; }
    if ($portchoice = 2) {
        def_int $pplot = ~house_find_plot_by_coord(loc_coord);
        if ($pplot < 0) { return; }
        loc_del(1);
        ~house_set_rfurn($pplot, 0);
        ~house_restore_room_furn($pplot);
        %house_portal_dest = 0;
        stat_advance(construction, 33000);
        mes("You dismantle the portal frame. (33,000 XP)");
        return;
    }
}
~house_portal_attune;

// ============================================================
// FURNITURE REMOVAL — use loc_coord to find the plot
// ============================================================

[oploc2,house_bed]
if (%building_mode < 1) { mes("You need building mode to remove furniture."); return; }
def_int $bp = ~house_find_plot_by_coord(loc_coord);
if ($bp < 0) { return; }
loc_del(1);
~house_set_rfurn($bp, 0);
~house_restore_room_furn($bp);
stat_advance(construction, 825);
mes("You dismantle the bed. (825 XP)");

